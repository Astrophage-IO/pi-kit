{
  "name": "pi-kit",
  "version": "0.1.0",
  "description": "Bun workspace for customized pi extensions and multi-agent coordination packages.",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "bun test packages/*/test/*.test.ts",
    "test:pi": "bun run packages/pi-bus/test/pi-rpc-smoke.ts",
    "typecheck": "tsc --noEmit",
    "proto:lint": "buf lint",
    "proto:generate": "buf generate",
    "pi-bus:start": "bun run packages/pi-bus/bin/pi-bus-server.ts",
    "pi-bus": "bun run packages/pi-bus/bin/pi-bus.ts",
    "pi-profile": "bun run packages/pi-profile/bin/pi-profile.ts",
    "changeset": "changeset",
    "version-packages": "changeset version && bun install --no-frozen-lockfile",
    "release": "changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Astrophage-IO/pi-kit.git"
  },
  "homepage": "https://github.com/Astrophage-IO/pi-kit#readme",
  "bugs": {
    "url": "https://github.com/Astrophage-IO/pi-kit/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@bufbuild/buf": "^1.69.0",
    "@bufbuild/protoc-gen-es": "^2.12.0",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0"
  }
}
